#!/usr/bin/env bash
# ============================================================
# hooks/session-start — Claude Code SessionStart 훅 (PWD 기반)
# ============================================================
# 목적: 세션 시작 시 현재 프로젝트($PWD)에 하네스가 설정되어
#       있으면 init.sh를 실행하고 결과를 에이전트 컨텍스트에 주입한다
# 조건: $PWD/feature-list.json이 존재할 때만 하네스 활성화
# ============================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HARNESS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
CURRENT_PROJECT="${PWD}"

# ── 현재 프로젝트에 하네스 파일이 있는지 확인 ───────────────
if [ ! -f "${CURRENT_PROJECT}/feature-list.json" ]; then
  # 하네스 미설정 프로젝트 — 사용자에게 설치 여부 확인 요청
  CONTEXT="이 프로젝트(${CURRENT_PROJECT})에는 하네스가 설정되어 있지 않습니다.
사용자에게 다음을 물어보세요: '이 프로젝트에 하네스를 설정할까요?'
- 사용자가 동의하면: bash ${HARNESS_DIR}/new-project.sh 를 실행한 뒤, feature-list.json을 열어 기능 목록을 작성하도록 안내하세요.
- 사용자가 거부하면: 그냥 진행하세요."

  escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"; s="${s//\"/\\\"}"; s="${s//$'\n'/\\n}"; s="${s//$'\r'/\\r}"; s="${s//$'\t'/\\t}"
    printf '%s' "$s"
  }
  CTX_ESC=$(escape_for_json "$CONTEXT")
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "${CTX_ESC}"
  exit 0
fi

# ── 하네스 활성 프로젝트 — init.sh를 현재 프로젝트 기준으로 실행 ─
INIT_OUTPUT=""
INIT_EXIT=0

# PROJECT_ROOT를 현재 프로젝트 디렉터리로 설정하여 init.sh 실행
INIT_OUTPUT=$(PROJECT_ROOT="${CURRENT_PROJECT}" bash "${HARNESS_DIR}/init.sh" 2>&1) || INIT_EXIT=$?

# 상태 메시지 결정
if [ "${INIT_EXIT}" -eq 0 ]; then
  STATUS_LINE="하네스 준비 완료 (프로젝트: ${CURRENT_PROJECT})"
else
  STATUS_LINE="하네스 오류 (종료 코드 ${INIT_EXIT}) — 작업 시작 전 반드시 진단하세요."
fi

# 컨텍스트 메시지 구성
CONTEXT="<harness-session-start>
${STATUS_LINE}

=== init.sh 출력 ===
${INIT_OUTPUT}
=== init.sh 출력 끝 ===

전체 프로토콜은 CLAUDE.md를 읽으세요.
코드 작성 전에 반드시 claude-progress.txt와 feature-list.json을 먼저 읽어야 합니다.
</harness-session-start>"

# JSON 이스케이프 함수
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

CONTEXT_ESCAPED=$(escape_for_json "$CONTEXT")

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "${CONTEXT_ESCAPED}"

exit 0
