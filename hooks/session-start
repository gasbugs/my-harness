#!/usr/bin/env bash
# ============================================================
# hooks/session-start — Claude Code SessionStart 훅
# ============================================================
# 목적: 세션 시작 시 init.sh를 자동으로 실행하고 결과를
#       에이전트 컨텍스트 창에 주입한다
# Claude Code는 hookSpecificOutput.additionalContext를 읽어
# 에이전트의 시스템 컨텍스트에 추가한다
# ============================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# init.sh 실행 및 출력 캡처
INIT_OUTPUT=""
INIT_EXIT=0

if [ -f "${PROJECT_ROOT}/init.sh" ]; then
  INIT_OUTPUT=$(bash "${PROJECT_ROOT}/init.sh" 2>&1) || INIT_EXIT=$?
else
  INIT_OUTPUT="경고: init.sh를 찾을 수 없습니다: ${PROJECT_ROOT}/init.sh"
  INIT_EXIT=1
fi

# 상태 메시지 결정
if [ "${INIT_EXIT}" -eq 0 ]; then
  STATUS_LINE="하네스 준비 완료 — 환경 초기화 성공."
else
  STATUS_LINE="하네스 오류 (종료 코드 ${INIT_EXIT}) — 작업 시작 전 반드시 진단하세요."
fi

# 컨텍스트 메시지 구성
CONTEXT="<harness-session-start>
${STATUS_LINE}

=== init.sh 출력 ===
${INIT_OUTPUT}
=== init.sh 출력 끝 ===

Claude Code 에이전트 하네스에 오셨습니다. 전체 프로토콜은 CLAUDE.md를 읽으세요.
코드 작성 전에 반드시 claude-progress.txt와 feature-list.json을 먼저 읽어야 합니다.
</harness-session-start>"

# JSON 이스케이프 함수
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

CONTEXT_ESCAPED=$(escape_for_json "$CONTEXT")

# Claude Code 훅 출력 형식으로 emit
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "${CONTEXT_ESCAPED}"

exit 0
