#!/usr/bin/env bash
# ============================================================
# hooks/pre-tool-guard — feature-list.json 보호 필드 수정 차단 (PWD 기반)
# ============================================================
# 목적: 현재 프로젝트($PWD)의 feature-list.json 보호 필드를 차단한다
#       $PWD에 feature-list.json이 없으면 즉시 통과
#
# Claude Code가 도구 입력을 stdin으로 JSON 형식으로 전달한다
# 종료 코드 0 = 도구 사용 허용
# 종료 코드 2 = 도구 사용 차단 (Claude Code 소프트 블록)
# ============================================================

set -uo pipefail

# 현재 프로젝트의 feature-list.json 경로
FEATURE_LIST="${PWD}/feature-list.json"

# 현재 프로젝트에 feature-list.json이 없으면 즉시 통과
if [ ! -f "${FEATURE_LIST}" ]; then
  exit 0
fi

# stdin에서 도구 입력 읽기
TOOL_INPUT=$(cat)

# 수정 대상 파일 경로 추출
TARGET_FILE=$(echo "${TOOL_INPUT}" | jq -r '.tool_input.path // .tool_input.file_path // ""' 2>/dev/null || echo "")

# 상대 경로를 절대 경로로 변환
if [[ "${TARGET_FILE}" != /* ]] && [ -n "${TARGET_FILE}" ]; then
  TARGET_FILE="${PWD}/${TARGET_FILE}"
fi

# 수정 대상이 이 프로젝트의 feature-list.json이 아니면 통과
if [ "${TARGET_FILE}" != "${FEATURE_LIST}" ]; then
  exit 0
fi

# 제안된 새 내용 추출
NEW_CONTENT=$(echo "${TOOL_INPUT}" | jq -r '.tool_input.new_string // .tool_input.content // ""' 2>/dev/null || echo "")

if [ -z "${NEW_CONTENT}" ]; then
  echo "[pre-tool-guard] 경고: feature-list.json의 제안 내용을 추출할 수 없습니다" >&2
  exit 0
fi

# 유효한 JSON인지 확인
if ! echo "${NEW_CONTENT}" | jq empty 2>/dev/null; then
  echo "[pre-tool-guard] 차단: 제안된 feature-list.json 내용이 유효한 JSON이 아닙니다" >&2
  exit 2
fi

# 플레이스홀더 상태 감지 — 초기 설정 단계면 보호 필드 수정 허용
# 조건: 예시 기능명("첫 번째 기능" 또는 "두 번째 기능")이 존재할 때만 허용
# (기능 수 기반 조건은 실제 작업 중인 프로젝트와 구분 불가하여 제외)
IS_PLACEHOLDER=false
PLACEHOLDER_BY_NAME=$(jq -r '[.features[].name] | map(select(. == "첫 번째 기능" or . == "두 번째 기능")) | length' "${FEATURE_LIST}" 2>/dev/null || echo "0")

if [ "${PLACEHOLDER_BY_NAME}" -gt 0 ]; then
  IS_PLACEHOLDER=true
fi

if [ "${IS_PLACEHOLDER}" = "true" ]; then
  # 초기 설정 단계 — 보호 필드 수정 허용
  exit 0
fi

# 보호 필드 비교 (id, name, description, notes)
CURRENT_PROTECTED=$(jq -c '[.features[] | {id,name,description,notes}]' "${FEATURE_LIST}" 2>/dev/null || echo "")
PROPOSED_PROTECTED=$(echo "${NEW_CONTENT}" | jq -c '[.features[] | {id,name,description,notes}]' 2>/dev/null || echo "")

if [ "${CURRENT_PROTECTED}" != "${PROPOSED_PROTECTED}" ] && [ -n "${CURRENT_PROTECTED}" ] && [ -n "${PROPOSED_PROTECTED}" ]; then
  echo "[pre-tool-guard] 차단: feature-list.json의 보호 필드(id/name/description/notes) 수정 시도 감지" >&2
  echo "[pre-tool-guard] 에이전트는 'passes' 필드만 수정할 수 있습니다." >&2
  exit 2
fi

# 기능 수 변경 여부 확인
CURRENT_COUNT=$(jq '.features | length' "${FEATURE_LIST}" 2>/dev/null || echo "0")
PROPOSED_COUNT=$(echo "${NEW_CONTENT}" | jq '.features | length' 2>/dev/null || echo "0")

if [ "${CURRENT_COUNT}" != "${PROPOSED_COUNT}" ]; then
  echo "[pre-tool-guard] 차단: feature-list.json에서 기능 추가/삭제 시도 감지" >&2
  exit 2
fi

exit 0
