#!/usr/bin/env bash
# ============================================================
# hooks/session-stop — Claude Code Stop 훅
# ============================================================
# 목적: 세션 종료 전 claude-progress.txt 작성 여부를 확인하고
#       미작성 시 에이전트에게 경고를 주입한다
# 조건: $PWD/feature-list.json이 존재하는 하네스 프로젝트만
# ============================================================

set -uo pipefail

FEATURE_LIST="${PWD}/feature-list.json"
PROGRESS_FILE="${PWD}/claude-progress.txt"

# 하네스 미설정 프로젝트면 스킵
if [ ! -f "${FEATURE_LIST}" ]; then
  exit 0
fi

# JSON 이스케이프 함수
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

emit_block() {
  # 경고 시 continue:false로 Claude 강제 중단 — 진행 로그 작성 전까지 종료 불가
  local msg="$1"
  local block="${2:-false}"
  local escaped
  escaped=$(escape_for_json "$msg")
  if [ "${block}" = "true" ]; then
    printf '{"continue":false,"stopReason":"%s"}\n' "${escaped}"
  else
    # Stop 훅은 hookSpecificOutput을 지원하지 않으므로 systemMessage 사용
    printf '{"systemMessage":"%s"}\n' "${escaped}"
  fi
}

# claude-progress.txt가 없으면 차단
if [ ! -f "${PROGRESS_FILE}" ]; then
  emit_block "⚠️ 하네스: claude-progress.txt가 없습니다. 종료 전 다음을 수행하세요: (1) claude-progress.txt 생성 (2) SESSION 1 블록 작성 (CLAUDE.md 형식 참고) (3) === END SESSION 1 === 으로 닫기" "true"
  exit 0
fi

# 열린 세션 블록 수 계산 (SESSION 수 - END SESSION 수)
OPEN_COUNT=$(awk '
  /^=== SESSION [0-9]/ && !/TEMPLATE/ { open++ }
  /^=== END SESSION [0-9]/ { open-- }
  END { print (open > 0 ? open : 0) }
' "${PROGRESS_FILE}")

if [ "${OPEN_COUNT}" -gt 0 ]; then
  LAST_SESSION=$(grep "^=== SESSION" "${PROGRESS_FILE}" | grep -v TEMPLATE | tail -1)
  emit_block "⚠️ 하네스: 닫히지 않은 세션 블록이 있습니다 (${LAST_SESSION}). 종료 전 다음을 수행하세요: (1) 마지막 세션 블록 완성 — Completed / Blocked / Test Results / Next Session Must 섹션 채우기 (2) === END SESSION N === 으로 닫기 (3) git commit" "true"
  exit 0
fi

# 정상 — 마지막 세션 정보 확인
LAST_CLOSED=$(grep "^=== END SESSION" "${PROGRESS_FILE}" | grep -v TEMPLATE | tail -1 || echo "없음")
emit_block "✅ 하네스: 진행 로그 정상 (${LAST_CLOSED}). 세션을 마무리합니다." "false"

exit 0
